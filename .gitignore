cat > .gitignore <<'EOF'
# Dependencies
node_modules/

# Build output
out/
dist/
build/

# VS Code packaged extension artifacts
*.vsix
extension.vsix

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime / temp files
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local scratch files used during development
a.txt
ficheros.txt
Pegado*.txt
Texto pegado*.txt
Se ha pegado*

# Local generated / oversized working images
biglogo.png

# Environment / secrets
.env
.env.*
!.env.example

# Editor metadata
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# Coverage / test output
coverage/
.nyc_output/

# Package manager cache
.npm/
.pnpm-store/

# Optional: keep only one lockfile.
# This project appears to be built with npm, so keep package-lock.json and ignore pnpm-lock.yaml.
pnpm-lock.yaml
EOF